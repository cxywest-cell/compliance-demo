# Travel Rule Compliance Demo — Environment Variables

# ──────────────────────────────────────────────
# Entity A — Originator (Customer of Custodian A)
# ──────────────────────────────────────────────
ENTITY_A_CLIENT_ID=lC0eHOAkD6sYYYR5hVpMFXCmC9ZaDD1k
ENTITY_A_SECRET=TS8cReg-ZE60XXB3U9midw3Hi4jIIl8O2Plo-5cZO9iQN5y2iIesfaqinRlsh7UQ
ENTITY_A_DID=did:trisa:entity-a-0x3f8a
ENTITY_A_CUSTODIAN_WALLET=0x3f8a...c71d
# NOTE: Wallets are generated & held by the custodian, not the customer

# ──────────────────────────────────────────────
# Custodian A — Originating VASP (custody provider)
# ──────────────────────────────────────────────
CUSTODIAN_A_CLIENT_ID=
CUSTODIAN_A_SECRET=
CUSTODIAN_A_DID=did:trisa:custodian-a-vasp
CUSTODIAN_A_VASP_CODE=VASP-CN-0892
CUSTODIAN_A_HOT_WALLET=0x7c4e...b93a
# Custodian A generates/holds wallets for Entity A customers

# ──────────────────────────────────────────────
# Entity B — Beneficiary (Customer of Custodian B)
# ──────────────────────────────────────────────
ENTITY_B_CLIENT_ID=
ENTITY_B_SECRET=
ENTITY_B_DID=did:trisa:entity-b-0x9e2b
ENTITY_B_CUSTODIAN_WALLET=0x9e2b...d48f
# NOTE: Wallets are generated & held by the custodian, not the customer

# ──────────────────────────────────────────────
# Custodian B — Beneficiary VASP (custody provider)
# ──────────────────────────────────────────────
CUSTODIAN_B_CLIENT_ID=
CUSTODIAN_B_SECRET=
CUSTODIAN_B_DID=did:trisa:custodian-b-vasp
CUSTODIAN_B_VASP_CODE=VASP-SG-1247
CUSTODIAN_B_HOT_WALLET=0x2d5a...e81c
# Custodian B generates/holds wallets for Entity B customers

# ──────────────────────────────────────────────
# TR Network
# ──────────────────────────────────────────────
TR_NETWORK_BASE_URL=
TR_NETWORK_API_VERSION=v1

# ──────────────────────────────────────────────
# Demo Defaults
