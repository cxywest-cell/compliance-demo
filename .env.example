# ============================================================
# Travel Rule Compliance Demo — Environment Variables
# Copy this file to .env and fill in your real values.
# All keys below are read by server.js at startup.
# ============================================================

# ─── Notabene: 4 Roles (Originator side) ────────────────────
# Entity A — Originator VASP's customer (originator)
ENTITY_A_CLIENT_ID=
ENTITY_A_SECRET=
ENTITY_A_DID=

# Custodian A — Originating VASP (custody provider for Entity A)
CUSTODIAN_A_CLIENT_ID=
CUSTODIAN_A_SECRET=
CUSTODIAN_A_DID=
CUSTODIAN_A_HOT_WALLET=

# ─── Notabene: 4 Roles (Beneficiary side) ───────────────────
# Entity B — Beneficiary VASP's customer (beneficiary)
ENTITY_B_CLIENT_ID=
ENTITY_B_SECRET=
ENTITY_B_DID=

# Custodian B — Beneficiary VASP (custody provider for Entity B)
CUSTODIAN_B_CLIENT_ID=
CUSTODIAN_B_SECRET=
CUSTODIAN_B_DID=
CUSTODIAN_B_HOT_WALLET=

# ─── Custody Wallets (Entity customer accounts) ─────────────
ENTITY_A_CUSTODIAN_WALLET=
ENTITY_B_CUSTODIAN_WALLET=

# ─── Sumsub KYC / KYB ───────────────────────────────────────
SUMSUB_APP_TOKEN=
SUMSUB_API_SECRET=
SUMSUB_WEBSDK_SECRET=

# ─── Webhook Signatures ─────────────────────────────────────
WEBHOOK_SECRET=
NOTABENE_WEBHOOK_SECRET=

# ─── Blockchain (optional, defaults shown) ──────────────────
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
