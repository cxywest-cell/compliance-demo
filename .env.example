# Travel Rule Compliance Demo — Environment Variables
# Copy this file to .env and fill in your real values.

# ──────────────────────────────────────────────
# Entity A — Originator (Customer of Custodian A)
# ──────────────────────────────────────────────
ENTITY_A_CLIENT_ID=
ENTITY_A_SECRET=
ENTITY_A_DID=
ENTITY_A_CUSTODIAN_WALLET=

# ──────────────────────────────────────────────
# Custodian A — Originating VASP (custody provider)
# ──────────────────────────────────────────────
CUSTODIAN_A_CLIENT_ID=
CUSTODIAN_A_SECRET=
CUSTODIAN_A_DID=
CUSTODIAN_A_VASP_CODE=
CUSTODIAN_A_HOT_WALLET=

# ──────────────────────────────────────────────
# Entity B — Beneficiary (Customer of Custodian B)
# ──────────────────────────────────────────────
ENTITY_B_CLIENT_ID=
ENTITY_B_SECRET=
ENTITY_B_DID=
ENTITY_B_CUSTODIAN_WALLET=

# ──────────────────────────────────────────────
# Custodian B — Beneficiary VASP (custody provider)
# ──────────────────────────────────────────────
CUSTODIAN_B_CLIENT_ID=
CUSTODIAN_B_SECRET=
CUSTODIAN_B_DID=
CUSTODIAN_B_VASP_CODE=
CUSTODIAN_B_HOT_WALLET=

# ──────────────────────────────────────────────
# Notabene Travel Rule Network
# ──────────────────────────────────────────────
TR_NETWORK_BASE_URL=https://api.eu1.notabene.id
TR_NETWORK_API_VERSION=v2
DEFAULT_ASSET=eip155:11155111/erc20:0x0136dE66891c0fb433C157A50f8CC796b0Fd0c66
DEFAULT_AMOUNT=5
DEFAULT_BLOCKCHAIN=sepolia

# ──────────────────────────────────────────────
# Sumsub KYC/KYB
# ──────────────────────────────────────────────
SUMSUB_APP_TOKEN=
SUMSUB_API_SECRET=
SUMSUB_WEBSDK_SECRET=
SUMSUB_BASE_URL=api.sumsub.com

# ──────────────────────────────────────────────
# Webhook
# ──────────────────────────────────────────────
WEBHOOK_SECRET=
NOTABENE_WEBHOOK_SECRET=
